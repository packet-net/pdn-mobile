{
  "name": "pdn-mobile",
  "private": true,
  "version": "0.0.0",
  "description": "pdn — native mobile UIs for the packet.net messaging apps (BBS, chat, WhatsPac), bootstrapped on a node-WebView shell (Capacitor 7 + React + TypeScript).",
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "cap:sync": "cap sync",
    "cap:copy": "cap copy"
  },
  "dependencies": {
    "@capacitor/core": "7.6.6",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@capacitor/cli": "7.6.6",
    "@types/react": "18.3.31",
    "@types/react-dom": "18.3.7",
    "@vitejs/plugin-react": "4.7.0",
    "typescript": "5.9.3",
    "vite": "5.4.21"
  }
}
