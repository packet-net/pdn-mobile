# capacitor.config.ts + the web build. Do not commit them.
ios/
android/

# Editor / OS cruft
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# TypeScript incremental build info
*.tsbuildinfo
