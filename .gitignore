# Dependencies
node_modules/

# Build output (Vite)
dist/
*.local

# iOS — generated in CI (Codemagic, macOS) via `cap add ios`, NOT checked in: it
# needs a Mac/Xcode and is reproducible from capacitor.config.ts + the web build.
ios/
# Android IS committed (it builds on Linux in hosted CI, no Mac) so its tracked native
# config — the cleartext network-security-config, the manifest — is reviewable + stable.
# Build outputs (build/, .gradle/, *.apk, local.properties) are excluded by android/.gitignore.

# Editor / OS cruft
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# TypeScript incremental build info
*.tsbuildinfo
